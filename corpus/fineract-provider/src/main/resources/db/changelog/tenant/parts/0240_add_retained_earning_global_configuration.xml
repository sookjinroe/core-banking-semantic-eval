<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <property name="current_datetime" value="NOW()"/>
    <changeSet author="fineract" id="1">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">select count(1) from c_configuration where name = 'last-day-of-financial-year'</sqlCheck>
        </preConditions>
        <insert tableName="c_configuration">
            <column name="name" value="last-day-of-financial-year"/>
            <column name="value" value="31" />
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="31: default for last day of fiscal year"/>
        </insert>
        <insert tableName="c_configuration">
            <column name="name" value="last-month-of-financial-year"/>
            <column name="value" value="12"/>
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="12: default for last month of fiscal year"/>
        </insert>
        <insert tableName="c_configuration">
            <column name="name" value="income-expense-gl-accounts"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value" value=""/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="List of income/expense GL account codes for retained earning calculation. Can provide multiple accounts separated by comma or ranges separated by dashes (e.g. 4000,5000-5999,7000). Empty by default, please set before executing job"/>
        </insert>
        <insert tableName="c_configuration">
            <column name="name" value="retained-gl-account"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value" value=""/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="Default retained gl account code. Empty by default, please set before executing job"/>
        </insert>
        <insert tableName="c_configuration">
            <column name="name" value="office-id"/>
            <column name="value" value="1"/>
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="OfficeId for which the report and the retained earning job will be executed"/>
        </insert>
        <insert tableName="c_configuration">
            <column name="name" value="retained-earning-used-by-report-name"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value" value="Trial Balance Summary Report with Asset Owner"/>
            <column name="enabled" valueBoolean="true"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="Report name which will be using using retained earning"/>
        </insert>
    </changeSet>
</databaseChangeLog>
